# Telegram userbot credentials — from https://my.telegram.org
TG_API_ID=
TG_API_HASH=
TG_PHONE=

# Session encryption — generate with: python scripts/generate_key.py
SESSION_ENCRYPTION_KEY=

# Notifier bot — optional. Leave blank to disable operator alerts.
# Strongly recommended for production. Without this, silent failures
# (bot crashes, prolonged disconnects) will not surface until manual check.
# Separate regular bot, NOT the userbot.
NOTIFIER_BOT_TOKEN=
NOTIFIER_CHAT_ID=

# Operational
HEARTBEAT_INTERVAL_SECONDS=60
LOG_LEVEL=INFO

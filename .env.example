# Session encryption — required. Generate with: python scripts/generate_key.py
SESSION_ENCRYPTION_KEY=

# Legacy single-account Telegram credentials. Optional from Phase 3 onward.
# If populated AND the database has no `accounts` rows, these are imported
# as the "Default" account on first start. After that, manage accounts via
# the web UI at http://127.0.0.1:8765.
TG_API_ID=
TG_API_HASH=
TG_PHONE=

# Notifier bot — optional. Leave blank to disable operator alerts.
# Strongly recommended for production. Without this, silent failures
# (bot crashes, prolonged disconnects) will not surface until manual check.
# Separate regular bot, NOT the userbot.
NOTIFIER_BOT_TOKEN=
NOTIFIER_CHAT_ID=

# Web UI
UI_PORT=8765
UI_AUTO_ACTIVATE=true   # if true, auto-connects the active account on startup

# Operational
HEARTBEAT_INTERVAL_SECONDS=60
LOG_LEVEL=INFO

# Local LLM (Ollama)
OLLAMA_HOST=http://127.0.0.1:11434
LLM_MODEL=                                 # set after reviewing docs/MODEL_SELECTION.md
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# Classifier
CLASSIFIER_CONFIDENCE_THRESHOLD=0.6        # below this fires a low_confidence operator alert

# History bootstrap
BOOTSTRAP_HISTORY_MESSAGES=100             # last N messages per chat to ingest
BOOTSTRAP_HISTORY_DAYS=30                  # OR last N days, whichever yields more
BOOTSTRAP_MAX_CONCURRENT=3                 # parallelism cap on bootstrap LLM calls
BACKLOG_MAX_CONCURRENT=5                   # parallelism cap on missed-message processing

# Resurface
RESURFACE_DORMANT_DAYS=14                  # inbound gap > this triggers 'resurface' signal

# Response generator
RESPONSE_TEMPERATURE=0.85
RESPONSE_MAX_TOKENS=200
RESPONSE_MAX_RETRIES=2                # re-rolls on AI-tell detection
RESPONSE_PERSONA_PATH=personas/default/persona.md

# Operator command access — comma-separated tg_user_ids (no spaces)
OPERATOR_USER_IDS=7636053235

# Reply gating defaults
DEFAULT_BOT_ENABLED_NEW_CHATS=1       # 1 = bot may reply to new chats by default; bootstrapped chats stay 0
